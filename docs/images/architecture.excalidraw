    {
      "id": "JbVeXS7CeIlHdUXBXlFNo",
      "type": "text",
      "x": 1080.9392026697647,
      "y": 1437.9992197000122,
      "width": 897.1834413136995,
      "height": 554.1313054108712,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "#ffc9c9",
      "fillStyle": "solid",
      "strokeWidth": 2,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "index": "b0I",
      "roundness": null,
      "seed": 912809601,
      "version": 959,
      "versionNonce": 632010121,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1778651054561,
      "link": null,
      "locked": false,
      "text": "Is everything a vector search ?\n\nWhat about knowledge graphs ?\n- graph-rag\n\nAll entities stored will have an\n\"embedding\" meta-data which describes\nthat entity which makes it searchable\n\n",
      "fontSize": 44.330504432869695,
      "fontFamily": 5,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Is everything a vector search ?\n\nWhat about knowledge graphs ?\n- graph-rag\n\nAll entities stored will have an \"embedding\" meta-data which describes that entity which makes it searchable\n\n",
      "autoResize": false,
      "lineHeight": 1.25
    },
